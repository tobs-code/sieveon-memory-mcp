# Sieveon - Environment Configuration
# Copy this file to .env and update values as needed

# SurrealDB Configuration
SURREALDB_URL=http://127.0.0.1:8000/sql
SURREALDB_USER=root
SURREALDB_PASS=root
SURREALDB_NS=sieveon
SURREALDB_DB=sieveon

# Server Ports
ROUTER_PORT=8080
PLANNER_PORT=8081
CONTROL_PLANE_PORT=8082

# Other Configuration
EMBEDDING_MODEL_NAME=all-MiniLM-L6-v2

# Groq API (alternative entity extraction, ~0.3s per text)
GROQ_API_KEY=

# Extraction method: "auto" → groq with spaCy fallback, "groq" → groq only, "spacy" → spaCy only
EXTRACTION_METHOD=auto
